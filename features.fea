     language dflt ;
      lookup markMarkPositioninglookup0;
      lookup markMarkPositioninglookupToLigature;
      lookup markConditionsLigatureFthochraPsifiston;
      lookup markConditionsLigatureFthochraGorgon;

 script byzm;
     language dflt ;
      lookup markMarkPositioninglookup0;
      lookup markMarkPositioninglookupToLigature;
      lookup markConditionsLigatureFthochraPsifiston;
      lookup markConditionsLigatureFthochraGorgon;

 script latn;
     language dflt ;
      lookup markMarkPositioninglookup0;
      lookup markMarkPositioninglookupToLigature;
      lookup markConditionsLigatureFthochraPsifiston;
      lookup markConditionsLigatureFthochraGorgon;
} mark;

