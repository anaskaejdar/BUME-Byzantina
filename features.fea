    sub \u1D0D3 \u1D0D0 by \diesis2Secondary;
    sub \u1D0D3 by \diesis8;
    sub \u1D0D2 by \diesis6;
    sub \u1D0D1 by \diesis4;
    sub \u1D0D0 by \diesis2;
