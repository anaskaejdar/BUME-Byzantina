@gorga.onFirstComponent=[\gorgonAbove.onFirstComponent
    \gorgonDottedLeft.onFirstComponent \gorgonDottedRight.onFirstComponent ];
@digorga.onFirstComponent=[\digorgon.onFirstComponent
    \digorgonDottedLeftBelow.onFirstComponent
    \digorgonDottedLeftAbove.onFirstComponent
    \digorgonDottedRight.onFirstComponent ];

@gorgaWithFirstComponentVariants = [\u1D08F \u1D090 \u1D091 \u1D092 \u1D093
    \u1D094 \u1D095 \u1D096 ];
@gorga.onFirstComponentVariants = [@gorga.onFirstComponent
    @digorga.onFirstComponent \trigorgon.onFirstComponent ];

lookup swapOnFirstComponentVariants {
  lookupflag UseMarkFilteringSet @gorgaWithFirstComponentVariants;
    # kentimata combos with implicit oligon
    sub \u1D053 @gorgaWithFirstComponentVariants' \u1D04E by @gorga.onFirstComponentVariants;
    sub \u1D046 @gorgaWithFirstComponentVariants' \u1D04E by @gorga.onFirstComponentVariants;
    sub \u1D051 @gorgaWithFirstComponentVariants' \u1D04E by @gorga.onFirstComponentVariants;
    sub \u1D055 @gorgaWithFirstComponentVariants' \u1D04E by @gorga.onFirstComponentVariants;
    sub \u1D055 @gorgaWithFirstComponentVariants' \u1D051 \u1D04E by @gorga.onFirstComponentVariants;
    sub \u1D051 @gorgaWithFirstComponentVariants' \u1D055 \u1D04E by @gorga.onFirstComponentVariants;
    sub \u1D056 @gorgaWithFirstComponentVariants' \u1D04E by @gorga.onFirstComponentVariants;
} swapOnFirstComponentVariants;

lookup ccmpPsalticBaseLigsWithMarktoLigature {
