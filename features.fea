@klasmata=[\u1D07F \u1D0F4 \klasmaAbove \klasmaBelow \karasTsakisma \karasTsakismaBelow ];
@klasmataSwapped=[\u1D0F4 \u1D07F \klasmaBelow \klasmaAbove \karasTsakismaBelow \karasTsakisma ];

lookup ccmpContextualReplacementsIgnoringMarksExceptKlasma {
  lookupflag UseMarkFilteringSet [@klasmata];
    sub @basesWithBottomKlasma @klasmata' by @klasmataSwapped;
} ccmpContextualReplacementsIgnoringMarksExceptKlasma;

lookup ccmpContextualSubstitutions2 {
  lookupflag 0;
    @normalAgogi = [\agogiTrueAgogiMesi \agogiPoliArgi \agogiArgoteri \agogiArgi \agogiMesi \agogiMetria \agogiGorgi \agogiGorgoteri \agogiPoliGorgi ];
    @aboveAgogi = [\agogiTrueAgogiMesiAbove \agogiPoliArgiAbove \agogiArgoteriAbove \agogiArgiAbove \agogiMesiAbove \agogiMetriaAbove \agogiGorgiAbove \agogiGorgoteriAbove \agogiPoliGorgiAbove ];
    sub [@practicalMartyriaTop @theoreticalMartyriaTop @martyrifiedFthoraTop \martyriaTick \u1D0AD ] @normalAgogi' by @aboveAgogi;
} ccmpContextualSubstitutions2;

feature salt {

 script DFLT;
     language dflt ;
      lookup saltStylisticAlternativesinByzantineMusiclookup4;

 script byzm;
     language dflt ;
      lookup saltStylisticAlternativesinByzantineMusiclookup4;
} salt;

feature rclt {

 script DFLT;
     language dflt ;
      lookup rcltRequiredContextualAlternateslookup3;
      lookup rcltRequiredContextualAlternateslookup1;

 script byzm;
     language dflt ;
      lookup rcltRequiredContextualAlternateslookup3;
      lookup rcltRequiredContextualAlternateslookup1;

 script latn;
     language dflt ;
      lookup rcltRequiredContextualAlternateslookup3;
      lookup rcltRequiredContextualAlternateslookup1;
} rclt;

feature ccmp {

 script DFLT;
     language dflt ;
      lookup ccmpWithinProperPsalticBlock;
      lookup ccmpOnetoMany0;
      lookup ccmpCombiningFthoraeChroaeYfesisDiesis;
      lookup ccmpContextualReplacements;
      lookup ccmpContextualReplacementsIgnoringMarks;
      lookup ccmpContextualReplacementsIgnoringMarksExceptKlasma;
      lookup swapOnFirstComponentVariants;
      lookup ccmpPsalticBaseLigsWithMarktoLigature;
      lookup ccmpPsalticBaseLigsConvertToOxeia;
      lookup ccmpPsalticBaseLigsConvertToOxeia2;
      lookup ccmpPsalticBaseLigs;
      lookup ccmpContextualSubstitutions2;
      lookup ccmpGlyphCompositionDecompositionlookup2;

 script byzm;
     language dflt ;
      lookup ccmpWithinProperPsalticBlock;
      lookup ccmpOnetoMany0;
      lookup ccmpCombiningFthoraeChroaeYfesisDiesis;
      lookup ccmpContextualReplacements;
      lookup ccmpContextualReplacementsIgnoringMarks;
      lookup ccmpContextualReplacementsIgnoringMarksExceptKlasma;
      lookup swapOnFirstComponentVariants;
      lookup ccmpPsalticBaseLigsWithMarktoLigature;
      lookup ccmpPsalticBaseLigsConvertToOxeia;
      lookup ccmpPsalticBaseLigsConvertToOxeia2;
      lookup ccmpPsalticBaseLigs;
      lookup ccmpContextualSubstitutions2;
      lookup ccmpGlyphCompositionDecompositionlookup2;

 script latn;
     language dflt ;
      lookup ccmpWithinProperPsalticBlock;
      lookup ccmpOnetoMany0;
      lookup ccmpCombiningFthoraeChroaeYfesisDiesis;
      lookup ccmpContextualReplacements;
      lookup ccmpContextualReplacementsIgnoringMarks;
      lookup ccmpContextualReplacementsIgnoringMarksExceptKlasma;
      lookup swapOnFirstComponentVariants;
      lookup ccmpPsalticBaseLigsWithMarktoLigature;
      lookup ccmpPsalticBaseLigsConvertToOxeia;
      lookup ccmpPsalticBaseLigsConvertToOxeia2;
      lookup ccmpPsalticBaseLigs;
      lookup ccmpContextualSubstitutions2;
      lookup ccmpGlyphCompositionDecompositionlookup2;
} ccmp;

