    sub [\u1D0D6 \u1D0D7 ] [\u1D0D6 \u1D0D7 ] \u1D0D6 by \yfesis6Tertiary;
    sub [\u1D0D5 \u1D0D7 ] [\u1D0D5 \u1D0D7 ] \u1D0D5 by \yfesis4Tertiary;
    sub \u1D0D7 \u1D0D7 \u1D0D4 by \yfesis2Tertiary;
    sub \u1D0D7 \u1D0D7 by \yfesis8Secondary;
    sub [\u1D0D6 \u1D0D7 ] \u1D0D6 by \yfesis6Secondary;
    sub [\u1D0D5 \u1D0D7 ] \u1D0D5 by \yfesis4Secondary;
    sub \u1D0D7 \u1D0D4 by \yfesis2Secondary;
    sub \u1D0D7 by \yfesis8;
    sub \u1D0D6 by \yfesis6;
    sub \u1D0D5 by \yfesis4;
    sub \u1D0D4 by \yfesis2;
    sub \u1D0D8 \u1D0D8 \u1D0D8 \u1D0D8 by \diesisGenikiTertiary;
    sub \u1D0D8 \u1D0D8 \u1D0D8 by \diesisGenikiSecondary;
