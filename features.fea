languagesystem DFLT dflt;
languagesystem byzm dflt;
languagesystem latn dflt;


# GSUB 


lookup saltStylisticAlternativesinByzantineMusiclookup4 {
  lookupflag 0;
    sub \psifiston from [\psifiston.salt01 ];
    sub \heteronConnecting from [\heteronConnecting.salt01 ];
    sub \modeFourth from [\modeFourth.salt01 ];
    sub \modeFirst from [\modeFirst.salt01 ];
} saltStylisticAlternativesinByzantineMusiclookup4;

lookup subs {
  lookupflag 0;
    sub \oligonKentimataBelow by \oligonKentimataBelow.alt01 ;
    sub \psifiston by \psifiston.alt01 ;
    sub \antikenoma by \antikenoma.alt01 ;
} subs;

lookup rcltRequiredContextualAlternateslookup3 {
  lookupflag 0;
    @cc1_match_1 = [\petastiIson \petasti \petastiOligon \petastiKentima \petastiYpsiliRight 
	\petastiYpsiliLeft \petastiKentimaYpsiliRight 
	\petastiKentimaYpsiliMiddle \petastiDoubleYpsili 
	\petastiKentimataDoubleYpsili \petastiKentimaDoubleYpsiliRight 
	\petastiKentimaDoubleYpsiliLeft \petastiTripleYpsili 
	\petastiKentimataTripleYpsili \petastiKentimaTripleYpsili 
	\petastiApostrofos \petastiYporroi \petastiElafron 
	\petastiRunningElafron \petastiElafronApostrofos \petastiChamili 
	\petastiChamiliApostrofos \petastiChamiliElafron 
	\petastiChamiliElafronApostrofos \petastiDoubleChamili 
	\petastiDoubleChamiliApostrofos ];
    @cc1_match_2 = [\antikenoma ];
    @cc1_back_1 = [\petastiIson \petasti \petastiOligon \petastiKentima \petastiYpsiliRight 
	\petastiYpsiliLeft \petastiKentimaYpsiliRight 
	\petastiKentimaYpsiliMiddle \petastiDoubleYpsili 
	\petastiKentimataDoubleYpsili \petastiKentimaDoubleYpsiliRight 
	\petastiKentimaDoubleYpsiliLeft \petastiTripleYpsili 
	\petastiKentimataTripleYpsili \petastiKentimaTripleYpsili 
	\petastiApostrofos \petastiYporroi \petastiElafron 
	\petastiRunningElafron \petastiElafronApostrofos \petastiChamili 
	\petastiChamiliApostrofos \petastiChamiliElafron 
	\petastiChamiliElafronApostrofos \petastiDoubleChamili 
	\petastiDoubleChamiliApostrofos ];
    @cc1_back_2 = [\antikenoma ];
    sub @cc1_back_1 @cc1_match_2'lookup subs  ;
} rcltRequiredContextualAlternateslookup3;

lookup ccmpGlyphCompositionDecompositionlookup2 {
  lookupflag 0;
    sub \oligonKentimataAbove \kentima  by \oligonKentimaMiddleKentimata;
    sub \oligon \kentima  by \oligonKentimaMiddle;
    sub \martyriaNoteNi \martyriaTick  by \martyriaNoteNiHigh;
    sub \martyriaNoteZo \martyriaTick  by \martyriaNoteZoHigh;
    sub \martyriaNotePa \martyriaTick  by \martyriaNotePaHigh;
    sub \martyriaNoteVou \martyriaTick  by \martyriaNoteVouHigh;
    sub \martyriaNoteGa \martyriaTick  by \martyriaNoteGaHigh;
    sub \martyriaNoteDi \martyriaTick  by \martyriaNoteDiHigh;
    sub \martyriaNoteKe \martyriaTick  by \martyriaNoteKeHigh;
} ccmpGlyphCompositionDecompositionlookup2;

lookup rcltRequiredContextualAlternateslookup1 {
  lookupflag 0;
    sub  \oligonKentimataBelow'lookup subs  \psifiston'  ;
    sub  \apostrofos' \antikenoma'lookup subs   ;
    sub  \yporroi' \antikenoma'lookup subs   ;
    sub  \oligonIsonKentimata' \psifiston'lookup subs   ;
    sub  \oligonElafronKentimata' \psifiston'lookup subs   ;
    sub  \oligonRunningElafronKentimata' \psifiston'lookup subs   ;
    sub  \oligonElafronApostrofosKentimata' \psifiston'lookup subs   ;
    sub  \oligonElafronApostrofosKentimata' \psifiston'lookup subs   ;
    sub  \oligonChamiliKentimata' \psifiston'lookup subs   ;
} rcltRequiredContextualAlternateslookup1;

lookup ccmpWithinProperPsalticBlock {
  lookupflag 0;
    # Double Kentima to Kentimata
    sub \u1D04F \u1D04F by \u1D04E;
    sub \u1D0F1 \u1D0F1 by \u1D0F0;
    sub \u1D0F3 \u1D0F3 by \u1D0F2;
    # Apli Dipli Tripli and Tetrapli
    sub \u1D085 \u1D085 \u1D085 \u1D085 by \u1D088;
    sub \u1D085 \u1D085 \u1D085 by \u1D087;
    sub \u1D085 \u1D085 by \u1D086;
    # Gorga and Arga
    sub \u1D08F \u1D08F \u1D08F by \u1D096;
    sub \u1D08F \u1D08F by \u1D092;
    sub \u1D090 \u1D08F by \u1D093;
    sub \u1D08F \u1D090 by \u1D094;
    sub \u1D08F \u1D091 by \u1D095;
    sub \u1D097 \u1D097 \u1D097 by \u1D099;
    sub \u1D097 \u1D097 by \u1D098;
    # Diesis and Yfesis
    sub \u1D0D0 \u1D0D0 \u1D0D0 \u1D0D0 by \u1D0D3;
    sub \u1D0D0 \u1D0D0 \u1D0D0 by \u1D0D2;
    sub \u1D0D0 \u1D0D0 by \u1D0D1;
    sub \u1D0D4 \u1D0D4 \u1D0D4 \u1D0D4 by \u1D0D7;
    sub \u1D0D4 \u1D0D4 \u1D0D4 by \u1D0D6;
    sub \u1D0D4 \u1D0D4 by \u1D0D5;
    # Agogi
    sub \u1D09E \u1D097 \u1D08F by \u1D09D;
    sub \u1D09E \u1D097 \u1D097 \u1D097 by \u1D09A;
    sub \u1D09E \u1D097 \u1D097 by \u1D09B;
    sub \u1D09E \u1D097 by \u1D09C;
    sub \u1D09E \u1D08F \u1D08F \u1D08F by \u1D0A1;
    sub \u1D09E \u1D08F \u1D08F by \u1D0A0;
    sub \u1D09E \u1D08F by \u1D09F;
    # Diastoli
    sub \u1D0DA \u1D0DA \u1D0DA by \u1D0DD;
    sub \u1D0DA \u1D0DA by \u1D0DC;
    # Double-Klasma Ano becomes Klasma Kato
    sub \u1D07F \u1D07F by \u1D0F4;
    sub \karasTsakisma \karasTsakisma by \karasTsakismaBelow;
    # Hxoi
    # sub \u1D0B1 \u1D0A3 by \u1D0B2; # Protovarys # TODO: Implement \u1D0B2
    # sub \u1D0A2 \u1D0A5 by \u1D0A2; # Wide Protos # TODO: Implement \u1D0A2
    # sub \u1D0B1 \u1D0A5 by \u1D0A4; # Wide Defteros # TODO: Implement \u1D0A4
} ccmpWithinProperPsalticBlock;

lookup ccmpOnetoMany0 {
    sub \u1D0B3 by \modePlagal \modePlagalFourth;
    sub \u1D08E by \leimma1 \gorgonAbove;
} ccmpOnetoMany0;

