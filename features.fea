@martyrifyableFthora = [\fthoraHardChromaticDiAbove \fthoraSoftChromaticKeAbove
    \chroaZygosAbove \chroaKlitonAbove \chroaSpathiAbove \karasThemaAploun ];
@martyrifiedFthora = [\u1D0C7.toHardChromaticDiMartyria
    \u1D0C4.toSoftChromaticKeMartyria \u1D0C8.toZygosMartyria
    \u1D0C9.toKlitonMartyria \u1D0CA.toSpathiMartyria
    \karasThemaAploun.toSabaaMartyria ];
@martyrifiedFthoraTop = [\u1D0C7.toHardChromaticDiMartyriaTop
    \u1D0C4.toSoftChromaticKeMartyriaTop \u1D0C8.toZygosMartyriaTop
    \u1D0C9.toKlitonMartyriaTop \u1D0CA.toSpathiMartyriaTop
    \karasThemaAploun.toSabaaMartyriaTop ];
@chromaticFthora = [
    \fthoraHardChromaticPaAbove \fthoraHardChromaticDiAbove \fthoraSoftChromaticDiAbove \fthoraSoftChromaticKeAbove
    \fthoraHardChromaticPaBelow \fthoraHardChromaticDiBelow \fthoraSoftChromaticDiBelow \fthoraSoftChromaticKeBelow
    \fthoraHardChromaticPaSecondary \fthoraHardChromaticDiSecondary \fthoraSoftChromaticDiSecondary \fthoraSoftChromaticKeSecondary
    \fthoraHardChromaticPaTertiary \fthoraHardChromaticDiTertiary \fthoraSoftChromaticDiTertiary \fthoraSoftChromaticKeTertiary
];
@theoreticalMartyria = [@martyrifiedFthora \u1D0A3 \u1D0A5 \u1D0A7 \u1D0A8 \u1D0A9 \u1D0B1];
@theoreticalMartyriaTop = [@martyrifiedFthoraTop \u1D0A3.toProtosMartyriaTop
    \u1D0A5.toPrimaryChromaticMartyriaTop \u1D0A7.toTritosMartyriaTop
    \u1D0A8.toTetartosMartyriaTop \u1D0A9.toLegetosMartyriaTop
    \u1D0B1.toVarysMartyriaTop ];
@practicalMartyria = [\u1D0E9 \u1D0EA \u1D0EB \u1D0EC \u1D0ED \u1D0EE \u1D0EF ];
@practicalMartyriaTop = [\u1D0E9.toPaMartyriaTop \u1D0EA.toVouMartyriaTop
    \u1D0EB.toGaMartyriaTop \u1D0EC.toDiMartyriaTop \u1D0ED.toKeMartyriaTop
    \u1D0EE.toZoMartyriaTop \u1D0EF.toNiMartyriaTop ];

lookup ccmpContextualReplacements {
  lookupflag 0;
    # Fanerosis Di-/Mono-/Tetrafonias
    sub [@practicalMartyria @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora \u1D0AD ] \u1D04F' by \u1D0B0;
    sub [\u1D0AF \u1D0AF.withMApos ] \u1D04F' by \u1D0B0.withMonofonias;
    sub [@practicalMartyria @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora ] \u1D0F3' by \u1D0AF;
    sub @practicalMartyria \u1D086' \u1D0F3' by \u1D0AF.withMApos;
    sub [\u1D0AD ] \u1D0F3' by \u1D0AF.withMApos;
    sub [@practicalMartyria @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora ] \u1D086' \u1D050' by \u1D0AE;
    # Ano Oxeia
    sub [@practicalMartyria @practicalMartyriaTop ] \u1D086' by \martyriaTick \martyriaTick;
    # Martyria Apostrofos (not for practical martyriae ^^^)
    sub [@practicalMartyria @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora ] \u1D086' by \u1D0AD;
    # Ano Oxeia
    sub [@practicalMartyria @practicalMartyriaTop @martyrifyableFthora @martyrifiedFthora @martyrifiedFthoraTop \martyriaTick ] \u1D086' by \martyriaTick \martyriaTick;
    sub [@practicalMartyria @practicalMartyriaTop @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora @martyrifiedFthoraTop \martyriaTick ] \u1D087' by \martyriaTick \martyriaTick \martyriaTick;
    sub [@practicalMartyria @practicalMartyriaTop @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora @martyrifiedFthoraTop \martyriaTick ] \u1D088' by \martyriaTick \martyriaTick \martyriaTick \martyriaTick;
    sub [@practicalMartyria @practicalMartyriaTop @theoreticalMartyria @martyrifyableFthora @martyrifiedFthora @martyrifiedFthoraTop \martyriaTick ] \u1D085' by \martyriaTick;
    # For lack of secondary chromatic theoretical martyriae in the unicode block
    # Replace the fthora with a bottom martyria in certain contexts
    ## sub [ \u1D046 - \u1D0F5 ] \u1D0AD' by \u1D0AD; # Prevent it from becoming a martyria if immediately preceded by something in the neume block
    sub @practicalMartyria @martyrifyableFthora' @practicalMartyria @practicalMartyria by @martyrifiedFthoraTop;
    sub @martyrifyableFthora' @practicalMartyria @practicalMartyria @practicalMartyria by @martyrifyableFthora;
    sub @martyrifyableFthora' @practicalMartyria @practicalMartyria by @martyrifyableFthora;
    sub [@practicalMartyria \martyriaTick \u1D0AD ] \u1D086 @martyrifyableFthora' by @martyrifiedFthoraTop;
    sub [\u1D0AD \martyriaTick @practicalMartyria ] @martyrifyableFthora' by @martyrifiedFthoraTop;
    sub @martyrifyableFthora' [\u1D0AD \u1D086 \martyriaTick @practicalMartyria ] by @martyrifiedFthora;
    # Use alternate codepoints for top martyriae
    sub [\u1D0AD \martyriaTick @practicalMartyria ] \u1D086 @theoreticalMartyria' by @theoreticalMartyriaTop;
    sub [\u1D0AD \martyriaTick @theoreticalMartyria ] \u1D086 @practicalMartyria' by @practicalMartyriaTop;
    sub [\u1D0AD \martyriaTick @practicalMartyria ] @theoreticalMartyria' by @theoreticalMartyriaTop;
    sub [\u1D0AD \martyriaTick @theoreticalMartyria ] @practicalMartyria' by @practicalMartyriaTop;
    # Turn doubled practical martyria into note indicator if preceded by chromatic martyria
    sub @chromaticFthora \u1D0E9' \u1D0E9' by \noteIndicatorPa;
    sub @chromaticFthora \u1D0EA' \u1D0EA' by \noteIndicatorVou;
    sub @chromaticFthora \u1D0EB' \u1D0EB' by \noteIndicatorGa;
    sub @chromaticFthora \u1D0EC' \u1D0EC' by \noteIndicatorDi;
    sub @chromaticFthora \u1D0ED' \u1D0ED' by \noteIndicatorKe;
    sub @chromaticFthora \u1D0EE' \u1D0EE' by \noteIndicatorZo;
    sub @chromaticFthora \u1D0EF' \u1D0EF' by \noteIndicatorNi;
    # Ison Markings After Martyrifyable Fthora
    sub @martyrifyableFthora \u1D0E9' \u1D0E9' \u1D0E9' by \isonIndicatorPa;
    sub @martyrifyableFthora \u1D0EA' \u1D0EA' \u1D0EA' by \isonIndicatorVou;
    sub @martyrifyableFthora \u1D0EB' \u1D0EB' \u1D0EB' by \isonIndicatorGa;
    sub @martyrifyableFthora \u1D0EC' \u1D0EC' \u1D0EC' by \isonIndicatorDi;
    sub @martyrifyableFthora \u1D0EC' \u1D0EC' \u1D0EC' \u1D0EC' by \isonIndicatorDiLow;
    sub @martyrifyableFthora \u1D0ED' \u1D0ED' \u1D0ED' by \isonIndicatorKe;
    sub @martyrifyableFthora \u1D0ED' \u1D0ED' \u1D0ED' \u1D0ED' by \isonIndicatorKeLow;
    sub @martyrifyableFthora \u1D0EE' \u1D0EE' \u1D0EE' by \isonIndicatorZo;
    sub @martyrifyableFthora \u1D0EE' \u1D0EE' \u1D0EE' \u1D0EE' by \isonIndicatorZoHigh;
    sub @martyrifyableFthora \u1D0EF' \u1D0EF' \u1D0EF' by \isonIndicatorNi;
    sub @martyrifyableFthora \u1D09E' \u1D09E' \u1D09E' by \isonIndicatorUnison;
    # Metrical numbers
    @barlines = [\barlineShortSingleAbove \barlineShortDoubleAbove \barlineShortTheseosAbove
        \barlineShortSingle \barlineShortDouble \barlineShortTheseos
        \barlineSingleAbove \barlineDoubleAbove \barlineTheseosAbove
        \barlineSingle \barlineDouble \barlineTheseos ];
    sub @barlines \u1D085' by \measureNumber2;
    sub @barlines \u1D086' by \measureNumber3;
    sub @barlines \u1D087' by \measureNumber4;
    sub @barlines \u1D088' \u1D085' by \measureNumber6;
    sub @barlines \u1D088' \u1D086' by \measureNumber7;
    sub @barlines \u1D088' \u1D087' by \measureNumber8;
    sub @barlines \u1D088' by \measureNumber5;
} ccmpContextualReplacements;

lookup ccmpContextualReplacementsIgnoringMarks {
